# SignDesk Backend Configuration
# Copy this file and fill in your values

# Server
PORT=3001
HOST=0.0.0.0
TRUST_PROXY=true

# Session (generate with: openssl rand -base64 32)
SESSION_SECRET=

# OIDC Provider
OIDC_ISSUER=https://auth.example.com/application/o/signdesk/
OIDC_CLIENT_ID=signdesk
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://signdesk.example.com/api/auth/callback
OIDC_POST_LOGOUT_URI=https://signdesk.example.com/
OIDC_SCOPES=openid profile email

# Storage
STORAGE_ROOT=/app/data
MAX_FILE_SIZE_MB=50
